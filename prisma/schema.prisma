generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

enum AccessStatus {
  ACTIVE
  GRACE
  BLOCKED
}

enum BillingStatus {
  UNKNOWN
  APPROVED
  PAYMENT_FAILED
  CANCELED
  REFUNDED
  CHARGEBACK
}

enum WebhookProcessingStatus {
  PROCESSED
  IGNORED
  FAILED
}

enum MagicLinkBridgeStatus {
  PENDING
  APPROVED
  CONSUMED
  EXPIRED
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stickers  Sticker[]
}

model Sticker {
  id         String           @id @default(cuid())
  slug       String           @unique
  title      String
  phrase     String
  imageUrl   String
  width      Int
  height     Int
  sizeKb     Int
  published  Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  categoryId String
  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants   StickerVariant[]
}

model StickerVariant {
  id         String   @id @default(cuid())
  colorHex   String
  imageUrl   String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  stickerId  String
  sticker    Sticker  @relation(fields: [stickerId], references: [id], onDelete: Cascade)

  @@index([stickerId, sortOrder])
}

model CustomerAccess {
  id                   String        @id @default(cuid())
  email                String        @unique
  accessStatus         AccessStatus  @default(BLOCKED)
  billingStatus        BillingStatus @default(UNKNOWN)
  graceUntil           DateTime?
  kiwifyCustomerId     String?
  kiwifyProductId      String?
  kiwifySubscriptionId String?
  lastEventType        String?
  lastEventAt          DateTime?
  lastApprovedAt       DateTime?
  lastPaymentFailedAt  DateTime?
  lastBlockedAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model KiwifyWebhookDelivery {
  id               String                  @id @default(cuid())
  dedupeKey        String                  @unique
  eventType        String
  email            String?
  payload          Json
  processingStatus WebhookProcessingStatus @default(PROCESSED)
  errorMessage     String?
  receivedAt       DateTime                @default(now())
  processedAt      DateTime?
}

model MagicLinkBridge {
  id           String                @id @default(cuid())
  email        String
  secretHash   String
  status       MagicLinkBridgeStatus @default(PENDING)
  exchangeCode String?               @unique
  approvedAt   DateTime?
  consumedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([email, createdAt])
  @@index([expiresAt])
}
