# Banco real: Prisma Postgres (db.prisma.io), conectado via marketplace da Vercel.
# Na Vercel a string aparece como POSTGRES_PRISMA_DATABASE_URL / POSTGRES_URL.
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
# Usada por `prisma migrate`/`db push`. Pode ser a mesma string do DATABASE_URL.
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://192.168.15.4:3000"
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM="no-reply@seu-dominio.com"
ADMIN_EMAIL="seu-email@dominio.com"
ADMIN_EMAILS="admin1@dominio.com,admin2@dominio.com"
EARLY_ACCESS_EMAIL="vip@dominio.com"
EARLY_ACCESS_EMAILS="vip1@dominio.com,vip2@dominio.com"
KIWIFY_WEBHOOK_TOKEN="troque-por-um-token-forte"
KIWIFY_SIMULATION_KEY="chave-simulacao-kiwify"
KIWIFY_ALLOWED_PRODUCT_IDS="id-produto-1,id-produto-2"
AUTH_BYPASS_FOR_PANEL="false"
